{
  "name": "front_end",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "onFail": "warn"
    }
  },
  "scripts": {
    "preinstall": "case \"${npm_config_user_agent:-}\" in *bun/*) ;; *) printf '\\nERROR: This project uses Bun.\\nRun: bun install\\n\\n' >&2; exit 1;; esac",
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "run-p lint:*",
    "lint:js": "eslint .",
    "lint:types": "tsc",
    "format": "prettier \"src/**/**.{js,jsx,ts,tsx}\" --write",
    "format:check": "prettier \"src/**/**.{js,jsx,ts,tsx}\" --check",
    "translations:generate": "node ./scripts/add_missing_translations.mjs",
    "pm2-runtime": "pm2 list && pm2-runtime start ecosystem.config.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --test",
    "test": "jest"
  },
